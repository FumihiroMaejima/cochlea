APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
# APP_LOCALE=ja
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# default
# DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

DB_CONNECTION=mysql
DB_MASTER_HOST=127.0.0.1
DB_MASTER_PORT=3306
DB_MASTER_DATABASE=laravel
DB_MASTER_USERNAME=root
DB_MASTER_PASSWORD=

DB_SLAVE_HOST="${DB_MASTER_HOST}"
DB_SLAVE_PORT="${DB_MASTER_PORT}"
DB_SLAVE_DATABASE="${DB_MASTER_DATABASE}"
DB_SLAVE_USERNAME="${DB_MASTER_USERNAME}"
DB_SLAVE_PASSWORD="${DB_MASTER_PASSWORD}"

# Other DB Connection Name
# mysql_logs
DB_LOGS_BASE_CONNECTION=sqlite
# mysql_user
DB_USER_BASE_CONNECTION=sqlite

# sharding setting
# logs DB
DB_LOGS_HOST="${DB_MASTER_HOST}"
DB_LOGS_PORT="${DB_MASTER_PORT}"
DB_LOGS_DATABASE="${DB_MASTER_DATABASE}_logs"
DB_LOGS_USERNAME="${DB_MASTER_USERNAME}"
DB_LOGS_PASSWORD="${DB_MASTER_PASSWORD}"

# user DB1
DB_USER1_HOST="${DB_MASTER_HOST}"
DB_USER1_PORT="${DB_MASTER_PORT}"
DB_USER1_DATABASE="${DB_MASTER_DATABASE}_user1"
DB_USER1_USERNAME="${DB_MASTER_USERNAME}"
DB_USER1_PASSWORD="${DB_MASTER_PASSWORD}"

# user DB2
DB_USER2_HOST="${DB_MASTER_HOST}"
DB_USER2_PORT="${DB_MASTER_PORT}"
DB_USER2_DATABASE="${DB_MASTER_DATABASE}_user2"
DB_USER2_USERNAME="${DB_MASTER_USERNAME}"
DB_USER2_PASSWORD="${DB_MASTER_PASSWORD}"

# user DB3
DB_USER3_HOST="${DB_MASTER_HOST}"
DB_USER3_PORT="${DB_MASTER_PORT}"
DB_USER3_DATABASE="${DB_MASTER_DATABASE}_user3"
DB_USER3_USERNAME="${DB_MASTER_USERNAME}"
DB_USER3_PASSWORD="${DB_MASTER_PASSWORD}"

# testing DB
DB_TESTING_HOST="${DB_MASTER_HOST}"
DB_TESTING_PORT="${DB_MASTER_PORT}"
DB_TESTING_DATABASE="${DB_MASTER_DATABASE}_testing"
DB_TESTING_USERNAME="${DB_MASTER_USERNAME}"
DB_TESTING_PASSWORD="${DB_MASTER_PASSWORD}"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# For Redis Connection
# SESSION_CONNECTION=redis-connection-name

# For Redis Connection
# SESSION_CONNECTION=redis-connection-name

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_STORE=file
# CACHE_STORE=redis
# CACHE_PREFIX=


MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
# REDIS_HOST=host.docker.internal
# REDIS_HOST=redis-cluster
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
### custom redis settings
REDIS_DB=0
REDIS_CLIENT=predis
IS_REDIS_CLUSTER_MODE=false
### redis datrabase
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_MASTER_CACHE_DB=1
REDIS_LOGIC_CACHE_DB=2


MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

### Custom Settings ###

# Log Setting(defalt : storage_path('logs/***.log'))
# LOG_ACCESS_PATH=/usr/local/app/log/access.log
# LOG_ERROR_PATH=/usr/local/app/log/error.log
# LOG_SQL_PATH=/usr/local/app/log/sql.log
# LOG_BATCH_PATH=/usr/local/app/log/batch.log
# LOG_ADIMIN_ACTION_PATH=/usr/local/admin/log/action.log
APP_LOG_DEFAULT_CHANNEL="error"
LOG_ACCESS_LEVEL=info
LOG_ERROR_LEVEL=error
LOG_SQL_LEVEL=info
LOG_BATCH_LEVEL=info
LOG_ADIMIN_ACTION_LEVEL=info

# Github OAuth Application
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=

# Json Web Token
JWT_SECRET=testSecretDefault0123456789abcdefghijklmnopqrstuvwxyz
JWT_TTL=30
JWT_REFRESH_TTL=120

# pepper
PEPPER=test_pepper

# Test Account Seeder Setting
TEST_USR_SEEDER_PASSWORD="password"
TEST_ADMIN_SEEDER_PASSWORD="password"

# Slack Message Setting
APP_SLACK_CHANNEL="channel_title"
APP_SLACK_NAME="bot-name"
APP_SLACK_ICON=:ghost:
APP_SLACK_WEBHOOK_URL=""

# Stripe Setting
STRIPE_PUBLIC_KEY=test_public_key
STRIPE_SECRET_KEY=test_private_key

# email encrypt keys
EMAIL_EBC_ENCRYPT_KEY=testXyZaBc159
EMAIL_CBC_ENCRYPT_KEY=12F3D3F82E573FA5

# frontend url
FRONTEND_URL=localhost:3000

# maintenance
IS_MAINTENANCE_MODE=false
MAINTENANCE_START_TIME='2022-01-01 00:00:00'
MAINTENANCE_END_TIME='2022-01-01 23:59:59'
IS_ENABLE_PASS_MAINTENANCE=false
MAINTENANCE_EXCEPT_ROUTE='/'
MAINTENANCE_EXCEPT_IP=127.0.0.1
